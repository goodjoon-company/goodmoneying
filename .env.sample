# 로컬 개발 런타임
GOODMONEYING_DEV_DIR=.dev
GOODMONEYING_API_HOST=127.0.0.1
GOODMONEYING_API_PORT=8000
GOODMONEYING_WEB_HOST=127.0.0.1
GOODMONEYING_WEB_PORT=5173
GOODMONEYING_POSTGRES_PORT=5432
GOODMONEYING_DATABASE_URL=postgresql://goodmoneying:goodmoneying@127.0.0.1:5432/goodmoneying
GOODMONEYING_OPERATOR_TOKEN=local-dev-token
GOODMONEYING_TIMEZONE=Asia/Seoul
GOODMONEYING_DEMO_DATA=0
GOODMONEYING_DASHBOARD_REFRESH_CONFIG=config/operations-api.yaml
GOODMONEYING_PYTHON_BIN=.venv/bin/python

# 업비트 수집 워커
GOODMONEYING_LIVE_UPBIT=1
GOODMONEYING_REALTIME_COLLECTION_INTERVAL_SECONDS=60
GOODMONEYING_BACKFILL_POLL_SECONDS=10
GOODMONEYING_BACKFILL_BATCH_SIZE=3000
GOODMONEYING_LOG_LEVEL=INFO

# Vite 단독 실행 또는 Playwright 수동 검증
VITE_DEV_API_PROXY_TARGET=http://127.0.0.1:8000
VITE_API_BASE_URL=/api
VITE_OPERATOR_TOKEN=local-dev-token
