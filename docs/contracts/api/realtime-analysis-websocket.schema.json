{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://goodmoneying.local/contracts/realtime-analysis-websocket.schema.json",
  "title": "코인 분석 WebSocket 메시지",
  "description": "분석 화면은 전체 화면 상태를 반복 전송하지 않고 type별 증분 메시지를 수신한다.",
  "oneOf": [
    { "$ref": "#/$defs/subscribe" }, { "$ref": "#/$defs/session" }, { "$ref": "#/$defs/instrument" }, { "$ref": "#/$defs/chart" },
    { "$ref": "#/$defs/indicators" }, { "$ref": "#/$defs/microstructure" }, { "$ref": "#/$defs/market" }, { "$ref": "#/$defs/candleUpsert" }, { "$ref": "#/$defs/indicatorUpsert" }, { "$ref": "#/$defs/microstructureUpsert" }, { "$ref": "#/$defs/error" }
  ],
  "$defs": {
    "envelope": { "type": "object", "required": ["version", "type", "sentAt"], "properties": { "version": { "const": "1" }, "type": { "type": "string" }, "sentAt": { "type": "string", "format": "date-time" } } },
    "candle": { "type": "object", "required": ["startedAt", "open", "high", "low", "close", "volume", "tradeAmount", "calculationVersion", "sourceAsOf", "knowledgeAt", "inputContentHash", "quality", "completeness"], "properties": { "startedAt": { "type": "string", "format": "date-time" }, "open": { "type": "string" }, "high": { "type": "string" }, "low": { "type": "string" }, "close": { "type": "string" }, "volume": { "type": "string" }, "tradeAmount": { "type": "string" }, "calculationVersion": { "type": "string" }, "sourceAsOf": { "type": "string", "format": "date-time" }, "knowledgeAt": { "type": "string", "format": "date-time" }, "inputContentHash": { "type": "string", "pattern": "^[0-9a-f]{64}$" }, "quality": { "enum": ["available", "no_trade", "missing", "unavailable", "unverified"] }, "completeness": { "enum": ["complete", "partial", "empty"] } } },
    "indicatorPoint": { "type": "object", "required": ["startedAt", "sma20", "sma60", "ema20", "bollingerUpper", "bollingerMiddle", "bollingerLower", "rsi14", "calculationStatus", "definitionVersions", "materializationId", "sourceRevisionThroughId", "qualityEventThroughId", "knowledgeAt", "sourceAsOf"], "properties": { "startedAt": { "type": "string", "format": "date-time" }, "sma20": { "type": ["string", "null"] }, "sma60": { "type": ["string", "null"] }, "ema20": { "type": ["string", "null"] }, "bollingerUpper": { "type": ["string", "null"] }, "bollingerMiddle": { "type": ["string", "null"] }, "bollingerLower": { "type": ["string", "null"] }, "rsi14": { "type": ["string", "null"] }, "calculationStatus": { "type": "object", "required": ["sma20", "sma60", "ema20", "bollinger20", "rsi14"], "additionalProperties": { "enum": ["warming_up", "ready", "missing"] } }, "definitionVersions": { "type": "object", "required": ["sma20", "sma60", "ema20", "bollinger20", "rsi14"], "additionalProperties": { "type": "string", "pattern": "^[0-9a-f]{64}$" } }, "materializationId": { "type": "integer", "minimum": 1 }, "sourceRevisionThroughId": { "type": "integer", "minimum": 0 }, "qualityEventThroughId": { "type": ["integer", "null"] }, "knowledgeAt": { "type": "string", "format": "date-time" }, "sourceAsOf": { "type": "string", "format": "date-time" } } },
    "microstructurePoint": {
      "type": "object",
      "required": ["startedAt", "calculationVersion", "closingOrderbookSnapshotId", "closingOrderbookSourceReceiptId", "spread", "spreadBps", "bidDepth10", "askDepth10", "orderbookImbalance10", "tradeCount", "tradeIntensityPerMinute", "volumeIntensityPerMinute", "buyCount", "sellCount", "buyVolume", "sellVolume", "buySellImbalance", "executionStrength", "orderbookStatus", "tradeStatus", "executionStrengthStatus", "materializationId", "sourceCandleRevisionId", "orderbookSnapshotThroughId", "tradeEventThroughId", "sourceReceiptThroughId", "connectionQualityThroughId", "qualityEventThroughId", "orderbookQuality", "tradeQuality", "sourceAsOf", "knowledgeAt", "inputLineageHash", "contentHash"],
      "properties": {
        "startedAt": { "type": "string", "format": "date-time" },
        "calculationVersion": { "const": "microstructure-v1" },
        "closingOrderbookSnapshotId": { "type": ["integer", "null"] },
        "closingOrderbookSourceReceiptId": { "type": ["integer", "null"] },
        "spread": { "type": ["string", "null"] },
        "spreadBps": { "type": ["string", "null"] },
        "bidDepth10": { "type": ["string", "null"] },
        "askDepth10": { "type": ["string", "null"] },
        "orderbookImbalance10": { "type": ["string", "null"] },
        "tradeCount": { "type": ["integer", "null"] },
        "tradeIntensityPerMinute": { "type": ["string", "null"] },
        "volumeIntensityPerMinute": { "type": ["string", "null"] },
        "buyCount": { "type": ["integer", "null"] },
        "sellCount": { "type": ["integer", "null"] },
        "buyVolume": { "type": ["string", "null"] },
        "sellVolume": { "type": ["string", "null"] },
        "buySellImbalance": { "type": ["string", "null"] },
        "executionStrength": { "type": ["string", "null"] },
        "orderbookStatus": { "$ref": "#/$defs/microstructureCalculationStatus" },
        "tradeStatus": { "$ref": "#/$defs/microstructureCalculationStatus" },
        "executionStrengthStatus": { "$ref": "#/$defs/microstructureCalculationStatus" },
        "materializationId": { "type": "integer", "minimum": 1 },
        "sourceCandleRevisionId": { "type": ["integer", "null"] },
        "orderbookSnapshotThroughId": { "type": "integer", "minimum": 0 },
        "tradeEventThroughId": { "type": "integer", "minimum": 0 },
        "sourceReceiptThroughId": { "type": "integer", "minimum": 0 },
        "connectionQualityThroughId": { "type": "integer", "minimum": 1 },
        "qualityEventThroughId": { "type": ["integer", "null"] },
        "orderbookQuality": { "$ref": "#/$defs/sourceQuality" },
        "tradeQuality": { "$ref": "#/$defs/sourceQuality" },
        "sourceAsOf": { "type": "string", "format": "date-time" },
        "knowledgeAt": { "type": "string", "format": "date-time" },
        "inputLineageHash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "contentHash": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
      }
    },
    "microstructureCalculationStatus": { "enum": ["ready", "missing", "partial", "invalid", "undefined"] },
    "sourceQuality": { "enum": ["available", "no_trade", "missing", "unavailable", "unverified"] },
    "subscribe": { "allOf": [{ "$ref": "#/$defs/envelope" }, { "properties": { "type": { "const": "analysis.subscribe" }, "instrumentId": { "type": "integer", "minimum": 1 }, "unit": { "enum": ["1m", "3m", "5m", "10m", "15m", "30m", "1h", "4h", "1d", "1w", "1M"] }, "rangeDays": { "enum": [1, 7, 30, 90, 365, 1095] } }, "required": ["instrumentId", "unit", "rangeDays"] }] },
    "session": { "allOf": [{ "$ref": "#/$defs/envelope" }, { "properties": { "type": { "const": "analysis.session" }, "subscriptionId": { "type": "string" } }, "required": ["subscriptionId"] }] },
    "instrument": { "allOf": [{ "$ref": "#/$defs/envelope" }, { "properties": { "type": { "const": "analysis.instrument" }, "instrument": { "type": "object", "required": ["id", "marketCode", "baseAsset", "quoteCurrency", "displayName"] } }, "required": ["instrument"] }] },
    "chart": { "allOf": [{ "$ref": "#/$defs/envelope" }, { "properties": { "type": { "const": "analysis.chart" }, "unit": { "enum": ["1m", "3m", "5m", "10m", "15m", "30m", "1h", "4h", "1d", "1w", "1M"] }, "chunkIndex": { "type": "integer", "minimum": 0 }, "chunkCount": { "type": "integer", "minimum": 1 }, "candles": { "type": "array", "maxItems": 500, "items": { "$ref": "#/$defs/candle" } } }, "required": ["unit", "chunkIndex", "chunkCount", "candles"] }] },
    "indicators": { "allOf": [{ "$ref": "#/$defs/envelope" }, { "properties": { "type": { "const": "analysis.indicators" }, "chunkIndex": { "type": "integer", "minimum": 0 }, "chunkCount": { "type": "integer", "minimum": 1 }, "revisionRefresh": { "type": "boolean" }, "points": { "type": "array", "maxItems": 500, "items": { "$ref": "#/$defs/indicatorPoint" } } }, "required": ["chunkIndex", "chunkCount", "points"] }] },
    "microstructure": { "allOf": [{ "$ref": "#/$defs/envelope" }, { "properties": { "type": { "const": "analysis.microstructure" }, "chunkIndex": { "type": "integer", "minimum": 0 }, "chunkCount": { "type": "integer", "minimum": 1 }, "revisionRefresh": { "type": "boolean" }, "points": { "type": "array", "maxItems": 500, "items": { "$ref": "#/$defs/microstructurePoint" } } }, "required": ["chunkIndex", "chunkCount", "points"] }] },
    "market": { "allOf": [{ "$ref": "#/$defs/envelope" }, { "properties": { "type": { "const": "analysis.market" }, "ticker": { "type": "object" }, "orderbook": { "type": "object" }, "tradeSummary": { "type": "object", "required": ["tradeCount", "buyVolume", "sellVolume", "lastTradeAt"] } }, "required": ["ticker", "orderbook", "tradeSummary"] }] },
    "candleUpsert": { "allOf": [{ "$ref": "#/$defs/envelope" }, { "properties": { "type": { "const": "analysis.candle.upsert" }, "candle": { "$ref": "#/$defs/candle" } }, "required": ["candle"] }] },
    "indicatorUpsert": { "allOf": [{ "$ref": "#/$defs/envelope" }, { "properties": { "type": { "const": "analysis.indicator.upsert" }, "point": { "$ref": "#/$defs/indicatorPoint" } }, "required": ["point"] }] },
    "microstructureUpsert": { "allOf": [{ "$ref": "#/$defs/envelope" }, { "properties": { "type": { "const": "analysis.microstructure.upsert" }, "point": { "$ref": "#/$defs/microstructurePoint" } }, "required": ["point"] }] },
    "error": { "allOf": [{ "$ref": "#/$defs/envelope" }, { "properties": { "type": { "const": "analysis.error" }, "code": { "enum": ["INVALID_MESSAGE", "NOT_WATCHLISTED", "NOT_FOUND"] }, "message": { "type": "string" } }, "required": ["code", "message"] }] }
  }
}
